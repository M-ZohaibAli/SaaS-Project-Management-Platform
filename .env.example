NODE_ENV=production
APP_URL=http://localhost:4173
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-32-byte-secret
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/orbitdesk?schema=public
REDIS_URL=redis://redis:6379
UPLOADTHING_SECRET=replace-with-uploadthing-secret
UPLOADTHING_APP_ID=replace-with-uploadthing-app-id
S3_BUCKET=orbitdesk-files
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=replace-with-access-key
S3_SECRET_ACCESS_KEY=replace-with-secret-key
OPENAI_API_KEY=replace-with-ai-provider-key
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
COOKIE_DOMAIN=localhost
CSRF_SECRET=replace-with-csrf-secret
ALLOWED_ORIGINS=http://localhost:4173,http://localhost:3000