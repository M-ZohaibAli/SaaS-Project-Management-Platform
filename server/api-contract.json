{
  "version": "1.0.0",
  "tenantHeader": "x-organization-id",
  "routes": [
    { "method": "POST", "path": "/api/auth/signup", "permission": "public", "body": ["name", "email", "password", "confirmPassword", "organization"] },
    { "method": "POST", "path": "/api/auth/login", "permission": "public", "body": ["email", "password"] },
    { "method": "POST", "path": "/api/auth/forgot-password", "permission": "public", "body": ["email"] },
    { "method": "POST", "path": "/api/auth/reset-password", "permission": "public", "body": ["token", "password"] },
    { "method": "GET", "path": "/api/auth/session", "permission": "authenticated" },
    { "method": "POST", "path": "/api/auth/refresh", "permission": "authenticated" },
    { "method": "POST", "path": "/api/auth/logout", "permission": "authenticated" },
    { "method": "GET", "path": "/api/organizations", "permission": "readOnly" },
    { "method": "POST", "path": "/api/organizations", "permission": "authenticated" },
    { "method": "PATCH", "path": "/api/organizations/:id", "permission": "manageTeam" },
    { "method": "DELETE", "path": "/api/organizations/:id", "permission": "deleteOrganization" },
    { "method": "GET", "path": "/api/members", "permission": "readOnly" },
    { "method": "PATCH", "path": "/api/members/:id/role", "permission": "manageTeam" },
    { "method": "DELETE", "path": "/api/members/:id", "permission": "manageTeam" },
    { "method": "GET", "path": "/api/invitations", "permission": "manageTeam" },
    { "method": "POST", "path": "/api/invitations", "permission": "manageTeam" },
    { "method": "POST", "path": "/api/invitations/:token/accept", "permission": "authenticated" },
    { "method": "GET", "path": "/api/projects", "permission": "readOnly" },
    { "method": "POST", "path": "/api/projects", "permission": "manageProjects" },
    { "method": "PATCH", "path": "/api/projects/:id", "permission": "manageProjects" },
    { "method": "DELETE", "path": "/api/projects/:id", "permission": "manageProjects" },
    { "method": "GET", "path": "/api/boards/:projectId", "permission": "readOnly" },
    { "method": "POST", "path": "/api/boards", "permission": "manageBoards" },
    { "method": "PATCH", "path": "/api/columns/:id", "permission": "manageBoards" },
    { "method": "GET", "path": "/api/tasks", "permission": "readOnly" },
    { "method": "POST", "path": "/api/tasks", "permission": "createTasks" },
    { "method": "PATCH", "path": "/api/tasks/:id", "permission": "createTasks" },
    { "method": "PATCH", "path": "/api/tasks/:id/move", "permission": "manageBoards" },
    { "method": "DELETE", "path": "/api/tasks/:id", "permission": "manageBoards" },
    { "method": "POST", "path": "/api/tasks/:id/checklist", "permission": "createTasks" },
    { "method": "PATCH", "path": "/api/checklist-items/:id", "permission": "createTasks" },
    { "method": "GET", "path": "/api/tasks/:id/comments", "permission": "readOnly" },
    { "method": "POST", "path": "/api/tasks/:id/comments", "permission": "comment" },
    { "method": "PATCH", "path": "/api/comments/:id", "permission": "comment" },
    { "method": "DELETE", "path": "/api/comments/:id", "permission": "comment" },
    { "method": "POST", "path": "/api/comments/:id/reactions", "permission": "comment" },
    { "method": "GET", "path": "/api/files", "permission": "readOnly" },
    { "method": "POST", "path": "/api/files/upload-url", "permission": "uploadFiles" },
    { "method": "POST", "path": "/api/files/complete", "permission": "uploadFiles" },
    { "method": "DELETE", "path": "/api/files/:id", "permission": "uploadFiles" },
    { "method": "GET", "path": "/api/activity", "permission": "readOnly" },
    { "method": "GET", "path": "/api/notifications", "permission": "readOnly" },
    { "method": "PATCH", "path": "/api/notifications/:id/read", "permission": "readOnly" },
    { "method": "PATCH", "path": "/api/notifications/read-all", "permission": "readOnly" },
    { "method": "GET", "path": "/api/search", "permission": "readOnly" },
    { "method": "GET", "path": "/api/analytics", "permission": "readOnly" },
    { "method": "GET", "path": "/api/calendar", "permission": "readOnly" },
    { "method": "GET", "path": "/api/notes/:projectId", "permission": "readOnly" },
    { "method": "PUT", "path": "/api/notes/:projectId", "permission": "createTasks" },
    { "method": "POST", "path": "/api/ai/tasks/extract", "permission": "createTasks" },
    { "method": "POST", "path": "/api/ai/tasks/:id/summary", "permission": "readOnly" },
    { "method": "POST", "path": "/api/ai/meetings/summary", "permission": "readOnly" },
    { "method": "POST", "path": "/api/ai/projects/:id/health", "permission": "readOnly" }
  ]
}